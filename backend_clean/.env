# Use SQLite for quick local testing
DATABASE_URL_OVERRIDE=sqlite:///./detectra.db
# Keep defaults for other services; adjust if you have Postgres/Redis
# POSTGRES_USER=detectra
# POSTGRES_PASSWORD=detectra_pass
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=detectra_db

# Run in development mode so app creates DB tables automatically
ENVIRONMENT=development

# Optional: set REDIS_URL if you have Redis running
# REDIS_URL=redis://localhost:6379/0
