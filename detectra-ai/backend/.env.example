# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Detectra AI"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=detectra
POSTGRES_PASSWORD=detectra_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=detectra_db

# ─── Redis & Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MODELS_DIR=models
TEMP_DIR=temp
MAX_VIDEO_SIZE_MB=500

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── AI Pipeline ──────────────────────────────────────────────────────────────
FRAME_EXTRACTION_FPS=1.0
YOLO_CONFIDENCE_THRESHOLD=0.5
LOGO_CONFIDENCE_THRESHOLD=0.7
MOTION_WINDOW_FRAMES=16
MOTION_WINDOW_FPS=8
WHISPER_MODEL_SIZE=base
YAMNET_WINDOW_S=0.96
FUSION_TIME_BIN_S=1.0
