# ═══════════════════════════════════════════════════════════════════════════════
# Detectra AI — Frontend Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── HuggingFace — AI Video Assistant (OPTIONAL) ─────────────────────────────
# Free token from https://huggingface.co/settings/tokens (Read access is enough)
# Without a token the Mistral-7B RAG chat still works but at lower rate limits
VITE_HF_TOKEN=

# ─── Backend API URL (OPTIONAL — development only) ───────────────────────────
# In development, Vite proxies /api → localhost:8000 automatically.
# In production with Docker/nginx, the reverse proxy handles routing — leave blank.
# Only set this if you are deploying the frontend WITHOUT the nginx proxy.
# VITE_API_URL=http://localhost:8000
