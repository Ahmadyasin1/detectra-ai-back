# ═══════════════════════════════════════════════════════════════════════════════
# Detectra AI — Frontend Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env  (or: copy .env.example .env  on Windows)
# 2. Fill in your values.
# 3. Never commit .env to version control.
#
# All variables are OPTIONAL. Leaving them blank runs the app in "guest mode"
# where account features (login, profile, history) are disabled but the AI
# analyzer + reports still work against the local backend.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (recommended for full functionality) ───────────────────────────
# Get these from Supabase Dashboard → Project Settings → API.
# Leave BOTH blank to run in guest mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Storage bucket name. Create this in Supabase Dashboard → Storage → New bucket.
# Defaults to 'videos' to match the migration in supabase/migrations/001_init.sql.
VITE_SUPABASE_STORAGE_BUCKET=videos

# ─── HuggingFace — AI Video Assistant (OPTIONAL) ─────────────────────────────
# Free token from https://huggingface.co/settings/tokens (Read access is enough).
# Without a token the Mistral-7B RAG chat still works but at lower rate limits.
VITE_HF_TOKEN=

# ─── Backend API URL (required for Vercel + separate API host) ───────────────
# Development: leave blank — Vite proxies /api and /ws to localhost:8000.
# Production (Vercel): set to your public API, e.g. https://api.detectra.example.com
# VITE_API_URL=https://your-api-host.example.com

# ─── Hero demo videos (optional, comma-separated URLs) ─────────────────────
# VITE_HERO_VIDEO_URLS=https://example.com/demo1.mp4,https://example.com/demo2.mp4

# ─── Error reporting (OPTIONAL) ──────────────────────────────────────────────
# Set to "true" to opt-in to verbose error capture in the ErrorBoundary.
# VITE_ENHANCED_ERROR_RECOVERY=true
