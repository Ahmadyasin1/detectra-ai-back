# ═══════════════════════════════════════════════════════════════════════════════
# Detectra AI — Production Environment Variables
# ─────────────────────────────────────────────────────
# 1. Copy:   cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Detectra AI"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_change_in_production_generate_new_one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=detectra
POSTGRES_PASSWORD=detectra_pass_change_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=detectra_db

# ─── Redis & Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_PORT=6379

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MODELS_DIR=models
TEMP_DIR=temp
MAX_VIDEO_SIZE_MB=500

# ─── API Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_MB=500

# ─── CORS (production) ───────────────────────────────────────────────────────
CORS_ORIGINS=["https://detectra-ai-main.vercel.app/","http://localhost:3000","http://127.0.0.1:3000","http://localhost:80"]
ALLOWED_ORIGINS=*

# ─── Supabase JWT (optional — recommended for production) ─────────────────────
SUPABASE_JWT_SECRET=

# ─── Frontend build vars (baked into the Vite bundle at build time) ──────────
VITE_SUPABASE_URL=https://txkwnceefmaotmqluajc.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_STORAGE_BUCKET=videos
VITE_HF_TOKEN=hf_your_huggingface_token_here
VITE_API_URL=http://localhost:8000

# ─── Docker ports ────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
HTTP_PORT=80

# ─── AI Pipeline ──────────────────────────────────────────────────────────────
FRAME_EXTRACTION_FPS=1.0
YOLO_CONFIDENCE_THRESHOLD=0.5
LOGO_CONFIDENCE_THRESHOLD=0.7
MOTION_WINDOW_FRAMES=16
MOTION_WINDOW_FPS=8
WHISPER_MODEL_SIZE=base
YAMNET_WINDOW_S=0.96
FUSION_TIME_BIN_S=1.0

# ─── ML Model Paths (override if using custom weight locations) ───────────────
# YOLO_SEG_MODEL=yolov8s-seg.pt
# YOLO_POSE_MODEL=yolov8n-pose.pt
# WHISPER_MODEL=small


SUPABASE_URL=https://txkwnceefmaotmqluajc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=videos
VITE_SUPABASE_STORAGE_BUCKET=videos