# ═══════════════════════════════════════════════════════════════════════════════
# Detectra AI — Backend + Docker Environment Variables
# ─────────────────────────────────────────────────────
# 1. Copy:   cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── API Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_MB=500
UPLOAD_DIR=./uploads

# ─── CORS (production) ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Leave unset or "*" for open access (dev).
# Example: ALLOWED_ORIGINS=https://detectra.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# ─── Supabase JWT (optional — recommended for production) ─────────────────────
# Get from: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# When set: API verifies Bearer tokens and enforces per-user job isolation.
# When blank: server runs in dev mode — all requests are treated as anonymous.
SUPABASE_JWT_SECRET=

# ─── Frontend build vars (used by docker-compose to build the React image) ───
# These are Vite public vars baked into the frontend bundle at build time.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_HF_TOKEN=
# API base URL seen by the browser. In Docker: http://localhost:8000
# In production behind nginx: https://your-domain.com (proxy strips /api prefix)
VITE_API_URL=http://localhost:8000

# ─── Docker ports ────────────────────────────────────────────────────────────
FRONTEND_PORT=3000    # frontend container mapped to host
HTTP_PORT=80          # nginx proxy port (production profile only)

# ─── ML Model Paths (override if using custom weight locations) ───────────────
# YOLO_SEG_MODEL=yolov8s-seg.pt
# YOLO_POSE_MODEL=yolov8n-pose.pt
# WHISPER_MODEL=small
